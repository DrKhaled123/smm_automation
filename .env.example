# =============================================================================
# SmartProxy — https://smartproxy.com/
# Use your actual username and password from the dashboard.
# DO NOT use the fake API endpoint from Setup B — SmartProxy uses HTTP proxy
# protocol, not a REST API for fetching proxies.
# =============================================================================
SMARTPROXY_USER=your_smartproxy_username
SMARTPROXY_PASSWORD=your_smartproxy_password
SMARTPROXY_GATE_HOST=gate.smartproxy.com
SMARTPROXY_GATE_PORT=7000
SMARTPROXY_SESSION_DURATION_MINUTES=25
SMARTPROXY_PROXY_TYPE=residential

# =============================================================================
# Steel Browser (self-hosted via Docker)
# Run: docker run -p 3000:3000 steel-dev/steel:latest
# =============================================================================
STEEL_BASE_URL=http://localhost:3000
STEEL_API_KEY=                      # Leave blank for self-hosted
STEEL_CONCURRENCY=5

# =============================================================================
# AdsPower — desktop app must be running on the same machine
# Local API docs: https://localapi-doc-en.adspower.com/
# =============================================================================
ADSPOWER_BASE_URL=http://127.0.0.1:50325
ADSPOWER_API_KEY=                   # Only needed on Team/Enterprise plans

# =============================================================================
# Redis (optional but recommended for accurate rate limiting across restarts)
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# =============================================================================
# General
# =============================================================================
LOG_LEVEL=INFO
HEADLESS=true
MAX_CONCURRENT_ACCOUNTS=5

# Daily action limits per account (tune conservatively)
LIMIT_LIKES=120
LIMIT_FOLLOWS=60
LIMIT_UNFOLLOWS=60
LIMIT_COMMENTS=30
LIMIT_POSTS=3
LIMIT_STORY_VIEWS=200
LIMIT_DMS=20
LIMIT_ACTIVE_START_HOUR=8
LIMIT_ACTIVE_END_HOUR=22
